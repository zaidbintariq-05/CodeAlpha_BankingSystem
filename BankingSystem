#include <iostream>
#include <fstream>
#include <string>
using namespace std;

class Customer {
public:
    string name;
    int customerId;
};

class Transaction {
public:
    int accountNumber;
    string type;
    double amount;

    void saveTransaction() {
        ofstream file("transactions.txt", ios::app);
        file << accountNumber << endl;
        file << type << endl;
        file << amount << endl;
        file.close();
    }
};
class Account {
public:
    Customer customer;
    int accountNumber;
    double balance;

    void createAccount() {
        cin.ignore();

        cout << "Enter Customer Name: ";
        getline(cin, customer.name);

        cout << "Enter Customer ID: ";
        cin >> customer.customerId;

        cout << "Enter Account Number: ";
        cin >> accountNumber;

        cout << "Enter Initial Balance: ";
        cin >> balance;
    }

    void displayAccount() {
        cout << "\n----- Account Information -----\n";
        cout << "Customer Name: " << customer.name << endl;
        cout << "Customer ID: " << customer.customerId << endl;
        cout << "Account Number: " << accountNumber << endl;
        cout << "Balance: " << balance << endl;
    }
};
void saveAccount(Account acc) 
{
    ofstream file("accounts.txt", ios::app);
    file << acc.customer.name << endl;
    file << acc.customer.customerId << endl;
    file << acc.accountNumber << endl;
    file << acc.balance << endl;

    file.close();
}
bool accountExists(int accNo) {
    ifstream file("accounts.txt");
    Account acc;

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        if (acc.accountNumber == accNo) {
            file.close();
            return true;
        }
    }

    file.close();
    return false;
}
void createNewAccount() {
    Account acc;
    acc.createAccount();

    if (accountExists(acc.accountNumber)) {
        cout << "Account number already exists!\n";
    } else {
        saveAccount(acc);
        cout << "Account created successfully!\n";
    }
}
void displayAllAccounts() {
    ifstream file("accounts.txt");
    Account acc;

    if (!file) {
        cout << "No accounts found!\n";
        return;
    }

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        acc.displayAccount();
    }

    file.close();
}
void depositMoney() {
    ifstream file("accounts.txt");
    ofstream temp("temp.txt");

    Account acc;
    int accNo;
    double amount;
    bool found = false;

    cout << "Enter Account Number: ";
    cin >> accNo;

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        if (acc.accountNumber == accNo) 
            {
            cout << "Enter Amount to Deposit: ";
            cin >> amount;

            if (amount > 0) 
             {
                acc.balance += amount;
                found = true;

                Transaction t;
                t.accountNumber = accNo;
                t.type = "Deposit";
                t.amount = amount;
                t.saveTransaction();

                cout << "Deposit successful!\n";
            }
             else 
            {
                cout << "Invalid amount!\n";
            }
        }

        temp << acc.customer.name << endl;
        temp << acc.customer.customerId << endl;
        temp << acc.accountNumber << endl;
        temp << acc.balance << endl;
    }

    file.close();
    temp.close();

    remove("accounts.txt");
    rename("temp.txt", "accounts.txt");

    if (!found) 
    {
        cout << "Account not found!\n";
    }
}
