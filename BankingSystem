#include <iostream>
#include <fstream>
#include <string>
using namespace std;

class Customer {
public:
    string name;
    int customerId;
};

class Transaction {
public:
    int accountNumber;
    string type;
    double amount;

    void saveTransaction() {
        ofstream file("transactions.txt", ios::app);
        file << accountNumber << endl;
        file << type << endl;
        file << amount << endl;
        file.close();
    }
};
class Account {
public:
    Customer customer;
    int accountNumber;
    double balance;

    void createAccount() {
        cin.ignore();

        cout << "Enter Customer Name: ";
        getline(cin, customer.name);

        cout << "Enter Customer ID: ";
        cin >> customer.customerId;

        cout << "Enter Account Number: ";
        cin >> accountNumber;

        cout << "Enter Initial Balance: ";
        cin >> balance;
    }

    void displayAccount() {
        cout << "\n----- Account Information -----\n";
        cout << "Customer Name: " << customer.name << endl;
        cout << "Customer ID: " << customer.customerId << endl;
        cout << "Account Number: " << accountNumber << endl;
        cout << "Balance: " << balance << endl;
    }
};
void saveAccount(Account acc) 
{
    ofstream file("accounts.txt", ios::app);
    file << acc.customer.name << endl;
    file << acc.customer.customerId << endl;
    file << acc.accountNumber << endl;
    file << acc.balance << endl;

    file.close();
}
bool accountExists(int accNo) {
    ifstream file("accounts.txt");
    Account acc;

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        if (acc.accountNumber == accNo) {
            file.close();
            return true;
        }
    }

    file.close();
    return false;
}
void createNewAccount() {
    Account acc;
    acc.createAccount();

    if (accountExists(acc.accountNumber)) {
        cout << "Account number already exists!\n";
    } else {
        saveAccount(acc);
        cout << "Account created successfully!\n";
    }
}
void displayAllAccounts() {
    ifstream file("accounts.txt");
    Account acc;

    if (!file) {
        cout << "No accounts found!\n";
        return;
    }

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        acc.displayAccount();
    }

    file.close();
}
void depositMoney() {
    ifstream file("accounts.txt");
    ofstream temp("temp.txt");

    Account acc;
    int accNo;
    double amount;
    bool found = false;

    cout << "Enter Account Number: ";
    cin >> accNo;

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        if (acc.accountNumber == accNo) 
            {
            cout << "Enter Amount to Deposit: ";
            cin >> amount;

            if (amount > 0) 
             {
                acc.balance += amount;
                found = true;

                Transaction t;
                t.accountNumber = accNo;
                t.type = "Deposit";
                t.amount = amount;
                t.saveTransaction();

                cout << "Deposit successful!\n";
            }
             else 
            {
                cout << "Invalid amount!\n";
            }
        }

        temp << acc.customer.name << endl;
        temp << acc.customer.customerId << endl;
        temp << acc.accountNumber << endl;
        temp << acc.balance << endl;
    }

    file.close();
    temp.close();

    remove("accounts.txt");
    rename("temp.txt", "accounts.txt");

    if (!found) 
    {
        cout << "Account not found!\n";
    }
}
void withdrawMoney() 
{
    ifstream file("accounts.txt");
    ofstream temp("temp.txt");

    Account acc;
    int accNo;
    double amount;
    bool found = false;

    cout << "Enter Account Number: ";
    cin >> accNo;

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        if (acc.accountNumber == accNo) {
            cout << "Enter Amount to Withdraw: ";
            cin >> amount;

            if (amount > 0 && amount <= acc.balance) {
                acc.balance -= amount;
                found = true;

                Transaction t;
                t.accountNumber = accNo;
                t.type = "Withdrawal";
                t.amount = amount;
                t.saveTransaction();

                cout << "Withdrawal successful!\n";
            } else {
                cout << "Insufficient balance or invalid amount!\n";
                found = true;
            }
        }

        temp << acc.customer.name << endl;
        temp << acc.customer.customerId << endl;
        temp << acc.accountNumber << endl;
        temp << acc.balance << endl;
    }

    file.close();
    temp.close();

    remove("accounts.txt");
    rename("temp.txt", "accounts.txt");

    if (!found) {
        cout << "Account not found!\n";
    }
}
void transferMoney() {
    int fromAcc, toAcc;
    double amount;

    cout << "Enter Sender Account Number: ";
    cin >> fromAcc;

    cout << "Enter Receiver Account Number: ";
    cin >> toAcc;

    cout << "Enter Amount to Transfer: ";
    cin >> amount;

    ifstream file("accounts.txt");
    ofstream temp("temp.txt");

    Account acc;
    bool senderFound = false;
    bool receiverFound = false;
    bool transferAllowed = false;

    while (getline(file, acc.customer.name)) {
        file >> acc.customer.customerId;
        file >> acc.accountNumber;
        file >> acc.balance;
        file.ignore();

        if (acc.accountNumber == fromAcc) {
            senderFound = true;

            if (amount > 0 && amount <= acc.balance) {
                acc.balance -= amount;
                transferAllowed = true;
            }
        }

        temp << acc.customer.name << endl;
        temp << acc.customer.customerId << endl;
        temp << acc.accountNumber << endl;
        temp << acc.balance << endl;
    }

    file.close();
    temp.close();

    remove("accounts.txt");
    rename("temp.txt", "accounts.txt");

    if (!senderFound) {
        cout << "Sender account not found!\n";
        return;
    }

    if (!transferAllowed) {
        cout << "Insufficient balance or invalid amount!\n";
        return;
    }

    ifstream file2("accounts.txt");
    ofstream temp2("temp.txt");

    while (getline(file2, acc.customer.name)) {
        file2 >> acc.customer.customerId;
        file2 >> acc.accountNumber;
        file2 >> acc.balance;
        file2.ignore();

        if (acc.accountNumber == toAcc) {
            acc.balance += amount;
            receiverFound = true;
        }

        temp2 << acc.customer.name << endl;
        temp2 << acc.customer.customerId << endl;
        temp2 << acc.accountNumber << endl;
        temp2 << acc.balance << endl;
    }

    file2.close();
    temp2.close();

    remove("accounts.txt");
    rename("temp.txt", "accounts.txt");

    if (receiverFound) {
        Transaction t1;
        t1.accountNumber = fromAcc;
        t1.type = "Transfer Sent";
        t1.amount = amount;
        t1.saveTransaction();

        Transaction t2;
        t2.accountNumber = toAcc;
        t2.type = "Transfer Received";
        t2.amount = amount;
        t2.saveTransaction();

        cout << "Transfer successful!\n";
    } else {
        cout << "Receiver account not found!\n";
    }
}
void viewTransactions() {
    ifstream file("transactions.txt");

    int searchAccNo;
    int accNo;
    string type;
    double amount;
    bool found = false;

    cout << "Enter Account Number: ";
    cin >> searchAccNo;

    cout << "\n Transaction History \n";

    while (file >> accNo) 
	{
        file.ignore();
        getline(file, type);
        file >> amount;
        file.ignore();

        if (accNo == searchAccNo) 
          {
            cout << "Type: " << type << " | Amount: " << amount << endl;
            found = true;
        }
    }

    file.close();

    if (!found) 
    {
        cout << "No transactions found for this account.\n";
    }
}

int main() 
    {
    int choice;

    do {
        cout << "\n Banking System \n";
        cout << "1. Create Account\n";
        cout << "2. Display All Accounts\n";
        cout << "3. Deposit Money\n";
        cout << "4. Withdraw Money\n";
        cout << "5. Transfer Money\n";
        cout << "6. View Transaction History\n";
        cout << "7. Exit\n";
        cout << "Enter Choice: ";
        cin >> choice;

        switch (choice) 
        {
        case 1:
            createNewAccount();
            break;

        case 2:
            displayAllAccounts();
            break;

        case 3:
            depositMoney();
            break;

        case 4:
            withdrawMoney();
            break;

        case 5:
            transferMoney();
            break;

        case 6:
            viewTransactions();
            break;

        case 7:
            cout << "Thank you for using Banking System.\n";
            break;

        default:
            cout << "Invalid choice!\n";
        }

    } 
    while (choice != 7);
    return 0;
}
